<odoo>

    <record id="hospital_doctor_view_tree" model="ir.ui.view">
        <field name="name">hospital.doctor.view.tree</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <tree string="">
                <field name="name" />
                <field name="user_id" />
                <field name="available" />
                <field name="specialty_id" />
            </tree>
        </field>
    </record>

    <record id="hospital_doctor_view_form" model="ir.ui.view">
        <field name="name">hospital.doctor.view.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="user_id" />
                        <field name="available" />
                        <field name="specialty_id" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="model_name_action" model="ir.actions.act_window">
        <field name="name">Action Name</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="doctors_sub_menu"
        name="doctors"
        parent="doctor_menu_items"
        action="model_name_action"
    />
</odoo>